# Production base URL for Vite (must end with /). Used by `vite build` and CI.
# Use `/` when the site is served at the domain root (custom domain, apex GitHub user site, etc.).
# For default *project* Pages only — https://<user>.github.io/<repo>/ — do not put /repo/ here:
# set the repository variable VITE_BASE_PATH to /milynotes/ in GitHub (Settings → Secrets and variables → Actions → Variables) so CI overrides this; see .github/workflows/ci.yml.
VITE_BASE_PATH=/
